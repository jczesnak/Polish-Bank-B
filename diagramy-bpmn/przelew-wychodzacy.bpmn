<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_PrzelewWychodzacy"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Bank" name="Polish Bank B" processRef="Process_Przelew" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Przelew" isExecutable="false">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Klient" name="Klient">
        <bpmn:flowNodeRef>SE1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="System bankowy">
        <bpmn:flowNodeRef>T2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T7</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T8</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>G4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T9</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>E_OK</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>E1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>E2</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="SE1" name="Zlecenie przelewu">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="T1" name="Wypełnij zlecenie (IBAN, kwota, tryb)">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T2" name="Walidacja IBAN (modulo 97)">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="G1" name="IBAN poprawny?">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F4</bpmn:outgoing>
      <bpmn:outgoing>F5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T3" name="Sprawdź dostępne środki">
      <bpmn:incoming>F4</bpmn:incoming>
      <bpmn:outgoing>F6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="G2" name="Pokrycie środków?">
      <bpmn:incoming>F6</bpmn:incoming>
      <bpmn:outgoing>F7</bpmn:outgoing>
      <bpmn:outgoing>F8</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T4" name="Załóż blokadę kwoty na koncie">
      <bpmn:incoming>F7</bpmn:incoming>
      <bpmn:outgoing>F9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="G3" name="Routing przelewu" default="F13">
      <bpmn:incoming>F9</bpmn:incoming>
      <bpmn:outgoing>F10</bpmn:outgoing>
      <bpmn:outgoing>F11</bpmn:outgoing>
      <bpmn:outgoing>F12</bpmn:outgoing>
      <bpmn:outgoing>F13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T5" name="Wyślij przez SWIFT">
      <bpmn:incoming>F10</bpmn:incoming>
      <bpmn:outgoing>F14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T6" name="Skieruj do SORBNET3 (RTGS)">
      <bpmn:incoming>F11</bpmn:incoming>
      <bpmn:outgoing>F15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T7" name="Skieruj do Express Elixir">
      <bpmn:incoming>F12</bpmn:incoming>
      <bpmn:outgoing>F16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T8" name="Dodaj do sesji ELIXIR">
      <bpmn:incoming>F13</bpmn:incoming>
      <bpmn:outgoing>F17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="G4" name="Zlecenie wysłane">
      <bpmn:incoming>F14</bpmn:incoming>
      <bpmn:incoming>F15</bpmn:incoming>
      <bpmn:incoming>F16</bpmn:incoming>
      <bpmn:incoming>F17</bpmn:incoming>
      <bpmn:outgoing>F18</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T9" name="Zaksięguj obciążenie i zwolnij blokadę">
      <bpmn:incoming>F18</bpmn:incoming>
      <bpmn:outgoing>F19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="E_OK" name="Przelew zrealizowany">
      <bpmn:incoming>F19</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="E1" name="Odrzucono: błędny numer konta">
      <bpmn:incoming>F5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="E2" name="Odrzucono: brak środków">
      <bpmn:incoming>F8</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="F1" sourceRef="SE1" targetRef="T1" />
    <bpmn:sequenceFlow id="F2" sourceRef="T1" targetRef="T2" />
    <bpmn:sequenceFlow id="F3" sourceRef="T2" targetRef="G1" />
    <bpmn:sequenceFlow id="F4" name="tak" sourceRef="G1" targetRef="T3" />
    <bpmn:sequenceFlow id="F5" name="nie" sourceRef="G1" targetRef="E1" />
    <bpmn:sequenceFlow id="F6" sourceRef="T3" targetRef="G2" />
    <bpmn:sequenceFlow id="F7" name="tak" sourceRef="G2" targetRef="T4" />
    <bpmn:sequenceFlow id="F8" name="nie" sourceRef="G2" targetRef="E2" />
    <bpmn:sequenceFlow id="F9" sourceRef="T4" targetRef="G3" />
    <bpmn:sequenceFlow id="F10" name="zagraniczny / obca waluta" sourceRef="G3" targetRef="T5" />
    <bpmn:sequenceFlow id="F11" name="&gt; 1 000 000 PLN" sourceRef="G3" targetRef="T6" />
    <bpmn:sequenceFlow id="F12" name="tryb natychmiastowy" sourceRef="G3" targetRef="T7" />
    <bpmn:sequenceFlow id="F13" name="zwykły krajowy" sourceRef="G3" targetRef="T8" />
    <bpmn:sequenceFlow id="F14" sourceRef="T5" targetRef="G4" />
    <bpmn:sequenceFlow id="F15" sourceRef="T6" targetRef="G4" />
    <bpmn:sequenceFlow id="F16" sourceRef="T7" targetRef="G4" />
    <bpmn:sequenceFlow id="F17" sourceRef="T8" targetRef="G4" />
    <bpmn:sequenceFlow id="F18" sourceRef="G4" targetRef="T9" />
    <bpmn:sequenceFlow id="F19" sourceRef="T9" targetRef="E_OK" />
  </bpmn:process>

